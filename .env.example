# Flasernos Configuration
# Copy this to .env and edit as needed

# Web UI port (default: 3000)
PORT=3000

# Bind address (default: 0.0.0.0 - all interfaces)
HOST=0.0.0.0

# Node environment
NODE_ENV=production

# Maximum upload file size in MB (default: 20)
MAX_UPLOAD_SIZE=20

# Discord bot token (auto-connect on startup)
# DISCORD_TOKEN=your_bot_token_here
